# Copy to .env and fill in values.

# Listmonk (API token auth recommended)
LISTMONK_BASE_URL=http://listmonk:9000
# LISTMONK_BASE_URL=http://localhost:9000  # host run
# LISTMONK_LIST_ID=1  # optional (processes all lists if unset)
LISTMONK_API_USER=validator
LISTMONK_API_TOKEN=replace_with_api_token
LISTMONK_EXCLUDE_NAME_SUBSTRINGS=test,sample

# Listmonk admin bootstrap (first install only)
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=admin123

# Prometheus / Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# Optional job tuning
VALIDATION_BATCH_SIZE=250
VALIDATION_POLL_INTERVAL_SECONDS=300
LISTMONK_WATERMARK_DB=data/listmonk_watermark.sqlite3
