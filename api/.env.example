# Copy to server/.env and fill in values.
# Used by the scrub API and celery-worker containers.

# API auth
API_KEY=replace_with_api_key

# Listmonk connection
LISTMONK_URL=http://listmonk:9000
LISTMONK_USER=validator
LISTMONK_PASS=replace_with_password
LISTMONK_LIST_ID=1
LISTMONK_BASE_URL=http://listmonk:9000
LISTMONK_API_USER=validator
LISTMONK_API_TOKEN=replace_with_api_token
LISTMONK_EXCLUDE_NAME_SUBSTRINGS=test,sample

# Job tuning
VALIDATION_BATCH_SIZE=250
VALIDATION_POLL_INTERVAL_SECONDS=300
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_RESTART_DELAY_SECONDS=10

# Watermark storage (Postgres)
WATERMARK_DB_URL=postgresql+psycopg2://listmonk:listmonk@listmonk_db:5432/listmonk

# Sentry (leave blank to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

# Zitadel JWT Auth
ZITADEL_DOMAIN=http://localhost:8080
ZITADEL_CLIENT_ID=your-zitadel-client-id
# Inside Docker, use container name so scrub can reach Zitadel internally
ZITADEL_JWKS_URL=http://zitadel:8080/oauth/v2/keys
