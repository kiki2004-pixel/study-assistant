# Copy to server/.env and fill in values.
# Used by the scrub API and celery-worker containers.

# API auth
API_KEY=replace_with_api_key

# Job tuning
VALIDATION_BATCH_SIZE=250
VALIDATION_POLL_INTERVAL_SECONDS=300
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_RESTART_DELAY_SECONDS=10

# Watermark storage (Postgres)
WATERMARK_DB_URL=postgresql+psycopg2://listmonk:listmonk@listmonk_db:5432/listmonk
